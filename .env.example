# ===== LINE Bot 設定 =====
# 從 LINE Developers Console > Messaging API 取得
LINE_CHANNEL_ACCESS_TOKEN=你的_Channel_Access_Token
LINE_CHANNEL_SECRET=你的_Channel_Secret

# ===== Ollama 設定 =====
# 本地 Ollama API 位址（預設）
OLLAMA_BASE_URL=http://localhost:11434
# 使用的模型名稱（需先用 ollama pull 下載，例如 qwen35、llama3.1、gemma2 等）
OLLAMA_MODEL=qwen35:latest
# 系統提示詞（可選，用來設定機器人的個性與回答風格）
OLLAMA_SYSTEM_PROMPT=你是一個友善的繁體中文助理，請用繁體中文簡潔回答使用者的問題。

# ===== Cloudflare Tunnel 設定 =====
# 對外固定網域（網域需已託管在 Cloudflare，且已用 cloudflared route dns 指到此 tunnel）
PUBLIC_DOMAIN=bot.linebotnanocat.com
# cloudflared 具名 tunnel 的名稱（cloudflared tunnel create <name> 建立的名稱）
CF_TUNNEL_NAME=linebot
# cloudflared 執行檔路徑；若已在系統 PATH 上，填 cloudflared 即可
CLOUDFLARED_PATH=cloudflared

# ===== 服務設定 =====
# WebUI 與 LINE Webhook 共用此埠
PORT=8080
