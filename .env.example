# ===== LINE Bot 設定 =====
# 從 LINE Developers Console > Messaging API 取得
LINE_CHANNEL_ACCESS_TOKEN=你的_Channel_Access_Token
LINE_CHANNEL_SECRET=你的_Channel_Secret

# ===== Ollama 設定 =====
# 本地 Ollama API 位址（預設）
OLLAMA_BASE_URL=http://localhost:11434
# 使用的模型名稱（需先用 ollama pull 下載，例如 qwen35、llama3.1、gemma2 等）
OLLAMA_MODEL=qwen35:latest
# 系統提示詞（可選，用來設定機器人的個性與回答風格）
OLLAMA_SYSTEM_PROMPT=你是一個友善的繁體中文助理，請用繁體中文簡潔回答使用者的問題。

# ===== Ngrok 設定 =====
# 首次使用 Ngrok 需到 https://dashboard.ngrok.com 取得 authtoken
NGROK_AUTHTOKEN=

# ===== 服務設定 =====
# WebUI 與 LINE Webhook 共用此埠
PORT=8080
