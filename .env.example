# ===== LINE Bot 設定 =====
# 從 LINE Developers Console > Messaging API 取得
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# 是否要求先加官方帳號好友才回覆（true/false）
LINE_REQUIRE_FRIEND=true
# 尚未加好友時自動回覆的訊息
LINE_NOT_FRIEND_MESSAGE=請先將我們加為好友後再傳訊息，謝謝！

# ===== Ollama 設定 =====
# 本地 Ollama API 位址（預設）
OLLAMA_BASE_URL=http://localhost:11434
# 使用的模型名稱（需先用 ollama pull 下載，例如 qwen3、llama3.1、gemma2 等）
OLLAMA_MODEL=qwen3
# 系統提示詞（可選，用來設定機器人的個性與回答風格）
OLLAMA_SYSTEM_PROMPT=你是一個友善的繁體中文助理，請用繁體中文簡潔回答使用者的問題。

# ===== 對話記憶設定 =====
# 是否啟用跨對話記憶（把過去對話壓縮成精華，下次對談前載入，true/false）
MEMORY_ENABLED=true
# 對話精華儲存資料夾（相對於專案根目錄或絕對路徑）
MEMORY_DIR=memory
# 每幾輪對話更新一次精華（1 表示每次都更新）
MEMORY_UPDATE_EVERY=1

# ===== Cloudflare Tunnel 設定 =====
# 對外固定網域（網域需已託管在 Cloudflare）。可留空後在 WebUI 安裝精靈填寫。
PUBLIC_DOMAIN=
# cloudflared 具名 tunnel 的名稱
CF_TUNNEL_NAME=linebot
# cloudflared 執行檔路徑；若已在系統 PATH 上，填 cloudflared 即可
CLOUDFLARED_PATH=cloudflared

# ===== WebUI 服務與安全性 =====
# WebUI 綁定位址。預設只綁本機（127.0.0.1）最安全；
# 要讓區網其他裝置存取才改成 0.0.0.0，並務必設定強密碼。
WEBUI_HOST=127.0.0.1
# WebUI 與 LINE Webhook 共用此埠
WEBUI_PORT=8080
# 控制台登入密碼。留空時啟動會自動產生臨時密碼並印在終端機；
# 正式使用請設定固定的強密碼。
WEBUI_PASSWORD=
# 登入 session 加密金鑰。留空時程式會自動產生並寫回此檔，無需手動填。
WEBUI_SECRET_KEY=

# ===== SQL Server 設定（選用）=====
# 是否啟用 SQL Server 連線（true/false）
SQLSERVER_ENABLED=false
# 主機與連接埠
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
# 資料庫名稱
SQLSERVER_DATABASE=
# 登入帳號；留空時改用 Windows 整合驗證（Trusted_Connection）
SQLSERVER_USER=
SQLSERVER_PASSWORD=
# ODBC 驅動名稱，例如 ODBC Driver 17 for SQL Server / ODBC Driver 18 for SQL Server
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
# 是否加密連線（Driver 18 預設要求，true/false）
SQLSERVER_ENCRYPT=false

# ===== 四層 AI 流水線（選用）=====
# 是否啟用四層流水線（語言理解→庫管→銷售→店長審查，true/false）
PIPELINE_ENABLED=false
# 各層模型；留空則使用 OLLAMA_MODEL 主模型。提示詞留空會用程式內建預設。
PIPELINE_L1_MODEL=
PIPELINE_L2_MODEL=
PIPELINE_L3_MODEL=
PIPELINE_L4_MODEL=

# ===== 原價屋報價（選用）=====
# 是否在缺貨時查原價屋報價（true/false）
COOLPC_ENABLED=true
# 原價屋報價頁網址
COOLPC_URL=https://www.coolpc.com.tw/evaluate.php
